# 复制为 .env 后再改值
# cp .env.example .env

# 必填: MiniMax API Key
MINIMAX_API_KEY=replace-with-your-key

# 可选: 也可使用 API_KEY 作为别名
# API_KEY=replace-with-your-key

# MiniMax 配置
APP_MINIMAX_BASE_URL=https://api.minimax.io/v1
APP_MINIMAX_MODEL=MiniMax-M2.5
# 若你的账号要求 GroupId（旧接口），在此填写
APP_MINIMAX_GROUP_ID=

# 服务端口
APP_PORT=8081

# 是否跳过启动时全量入库 (true/false)
SKIP_INGEST=true

# 法规库根目录
APP_CORPUS_ROOT_PATH=/Users/brandonbot/APPdev/政策法规2.20
