# 复制为 .env 后再改值
# cp .env.example .env

# 必填: MiniMax API Key
MINIMAX_API_KEY=replace-with-your-key

# 可选: 也可使用 API_KEY 作为别名
# API_KEY=replace-with-your-key

# MiniMax 配置
APP_MINIMAX_BASE_URL=https://api.minimax.io/v1
APP_MINIMAX_MODEL=MiniMax-M2.5
# 若你的账号要求 GroupId（旧接口），在此填写
APP_MINIMAX_GROUP_ID=

# 服务端口
APP_PORT=8081

# 启动入库策略:
# - true: 若已有 .run/vector-store.json 则跳过；若无索引则自动首启入库
# - false: 每次启动都执行全量入库
SKIP_INGEST=true

# 法规库根目录（默认使用仓库下 ./corpus）
APP_CORPUS_ROOT_PATH=./corpus

# 快速模式法规库目录（默认使用仓库下 ./fast-corpus）
APP_FAST_MODE_ROOT_PATH=./fast-corpus

# Embedding 服务（bge-large-zh）
APP_EMBEDDING_ENABLED=true
APP_EMBEDDING_BASE_URL=http://localhost:8000
APP_EMBEDDING_ENDPOINT=/v1/embeddings
APP_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
